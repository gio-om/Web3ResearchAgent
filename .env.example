BOT_TOKEN=bot_token
NGROK_AUTHTOKEN=ngrok_token
WEBAPP_URL=https://your-domain.ngrok-free.dev

# LLM model (через OmniRoute — менять только это)
# Дашборд OmniRoute: http://localhost:20128  пароль: 123456
OPENAI_MODEL=glm/glm-5.1

CRYPTORANK_COOKIE=
CRYPTORANK_BEARER=
CRYPTORANK_API_KEY=your_cryptorank_key
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

DATABASE_URL=postgresql+asyncpg://web3dd:web3dd_secret@postgres:5432/web3dd
REDIS_URL=redis://redis:6379/0

REQUEST_TIMEOUT=30
MAX_CONCURRENT_REQUESTS=10
API_PORT=8080
